# The Invisible City — environment configuration
# Copy to .env and adjust. NO secrets belong in the frontend; all keys stay
# server-side. Every value has a production-safe default except the credentialed
# providers (CAMS, DELFI) which stay OFF until configured.

# --- Server ---
PORT=3001
HOST=127.0.0.1
# WEB_ROOT=apps/web/dist        # served automatically when the web build exists
CACHE_DB=var/cache.sqlite

# --- Demo mode (DEV ONLY) ---
# Off by default. When '1', the /api/*?demo=1 paths serve labelled fixtures.
# Never enable in production. Demo and live data never mix.
ENABLE_DEMO=0

# --- Keyless public providers (defaults shown; override to self-host) ---
# BRIGHTSKY_URL=https://api.brightsky.dev
# DWD_WFS_URL=https://maps.dwd.de/geoserver/dwd/ows
# UBA_BASE_URL=https://luftdaten.umweltbundesamt.de/api/air_data/v3
# OVERPASS_URL=https://overpass-api.de/api/interpreter
# PHOTON_URL=https://photon.komoot.io          # self-host recommended for production

# --- CAMS regional air-quality model (optional; requires Copernicus ADS key) ---
# Register at https://ads.atmosphere.copernicus.eu and paste the API key here.
# Without it the app reports "Konfiguration erforderlich" (never demo/invented).
# CAMS_ADS_URL=https://ads.atmosphere.copernicus.eu/api
# CAMS_ADS_KEY=

# --- DELFI GTFS static timetable (optional; requires a feed) ---
# Import with:  npm run gtfs:import --workspace apps/api -- <path-or-url-to-gtfs.zip>
# then set the path so the transit provider activates. See docs/data-sources.md
# for DELFI registration/license (https://www.opendata-oepnv.de/).
# GTFS_DB=var/gtfs.sqlite
# GTFS_STATIC_PATH=/data/delfi-gtfs.zip
# GTFS_STATIC_URL=

# --- GTFS-Realtime (optional; requires a stream; coverage is PARTIAL) ---
# GTFS_RT_URL=
# GTFS_RT_KEY=

# --- V1.1 keyless providers (defaults shown; override to self-host) ---
# PEGELONLINE_URL=https://www.pegelonline.wsv.de/webservices/rest-api/v2
# BFS_ODL_URL=https://www.imis.bfs.de/ogc/opendata/ows
# DWD_HEALTH_URL=https://opendata.dwd.de/climate_environment/health/alerts

# --- V1.2 keyless providers (defaults shown; override to self-host) ---
# NINA_URL=https://warnung.bund.de/api31
# BKG_WFS_URL=https://sgx.geodatenzentrum.de/wfs_vg250
# AUTOBAHN_URL=https://verkehr.autobahn.de/o/autobahn
# GEOFON_URL=https://geofon.gfz-potsdam.de/fdsnws/event/1
# DWD_CDC_NORMALS_URL=https://opendata.dwd.de/climate_environment/CDC/observations_germany/climate/multi_annual/mean_91-20

# --- Fuel prices (optional; free key from https://creativecommons.tankerkoenig.de) ---
# TANKERKOENIG_URL=https://creativecommons.tankerkoenig.de/json
# TANKERKOENIG_API_KEY=

# --- DB station elevators/escalators (optional; free credentials from the
#     DB API Marketplace, https://developers.deutschebahn.com) ---
# DB_FASTA_URL=https://apis.deutschebahn.com/db-api-marketplace/apis/fasta/v2
# DB_CLIENT_ID=
# DB_API_KEY=
