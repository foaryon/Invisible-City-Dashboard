{
  "name": "invisible-city",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The Invisible City — Reality-first spatial intelligence dashboard for Germany. Integration, evidence & comparison layer over documented public data interfaces.",
  "license": "MIT",
  "engines": {
    "node": ">=22.11.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspaces --if-present",
    "app": "npm run build --workspace apps/web && npm run start --workspace apps/api",
    "build:server": "node scripts/build-server.mjs",
    "start:bundle": "node apps/api/dist/server.mjs",
    "build:standalone": "node scripts/build-standalone.mjs",
    "icons": "node scripts/gen-icons.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:web": "vitest run --project web",
    "test:node": "vitest run --project node",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run format:check && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.30.0",
    "@playwright/test": "^1.53.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^3.2.7",
    "@yao-pkg/pkg": "^6.21.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.30.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
