{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://invisible-city.local/schemas/test-evidence-manifest/1.0.0",
  "title": "Test Evidence Manifest",
  "description": "The only valid carrier of verification verdicts for Invisible City compliance requirements. A claim of completion, coverage or compliance that is not backed by a manifest conforming to this schema is invalid by definition (TEST_GOVERNANCE.md rule 4). Manifests are produced by commands (test runners, the diagnose harness, audit scripts) or, for manual rubric items, by a structured attestation — never by prose.",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_schema_version", "run", "targets", "results", "summary"],
  "properties": {
    "manifest_schema_version": {
      "const": "1.0.0"
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["git_sha", "git_dirty", "command", "environment", "started_at", "finished_at"],
      "properties": {
        "git_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$",
          "description": "Commit the run executed against. A dirty tree MUST set git_dirty true — verdicts from dirty trees cannot flip a matrix status to covered."
        },
        "git_dirty": { "type": "boolean" },
        "command": {
          "type": "string",
          "minLength": 1,
          "description": "Exact reproducible command line (e.g. 'npm run verify', 'npx playwright test', 'npm run diagnose')."
        },
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["os", "node", "ci"],
          "properties": {
            "os": { "type": "string", "minLength": 1 },
            "node": { "type": "string", "minLength": 1 },
            "ci": {
              "type": "boolean",
              "description": "true when produced by the CI pipeline; GD-TEST-03 requires local AND CI evidence for completion claims."
            },
            "label": {
              "type": "string",
              "description": "Optional human label, e.g. 'Windows 11 target system' for GD-GFX attestations."
            }
          }
        },
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirements_doc_sha256", "matrix_sha256"],
      "properties": {
        "requirements_doc_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "sha256 of MASTERPROMPT_REQUIREMENTS.md the verdicts refer to. A manifest against a stale spec hash is void."
        },
        "matrix_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "sha256 of MASTERPROMPT_TEST_MATRIX.yaml the verdicts refer to."
        }
      }
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/result" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pass", "fail", "blocked", "waived"],
      "properties": {
        "pass": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "waived": { "type": "integer", "minimum": 0 }
      },
      "description": "Counts MUST equal the verdict tally of results[]; a consuming gate recomputes and rejects mismatches."
    }
  },
  "$defs": {
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_id", "verdict", "oracle_results", "evidence"],
      "properties": {
        "requirement_id": {
          "type": "string",
          "pattern": "^(MP|DEV|DOC|GD)-[A-Za-z0-9.]+-?[0-9]*$",
          "description": "An ID present in MASTERPROMPT_REQUIREMENTS.md / the matrix."
        },
        "verdict": { "enum": ["pass", "fail", "blocked", "waived"] },
        "oracle_results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["oracle_index", "type", "passed"],
            "properties": {
              "oracle_index": {
                "type": "integer",
                "minimum": 0,
                "description": "Index into the matrix entry's oracles[] for this requirement."
              },
              "type": {
                "enum": [
                  "dom",
                  "state",
                  "network",
                  "console",
                  "screenshot",
                  "a11y",
                  "provenance",
                  "process",
                  "rubric"
                ]
              },
              "passed": { "type": "boolean" },
              "detail": {
                "type": "string",
                "description": "On failure: observed vs expected. Mandatory in spirit for verdict=fail."
              }
            }
          },
          "description": "One entry per matrix oracle exercised. A pass verdict with zero oracle results is only valid for pure cross-reference bundle requirements."
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "path", "sha256", "created_at"],
            "properties": {
              "type": {
                "enum": [
                  "junit",
                  "screenshot",
                  "har",
                  "console-log",
                  "diagnose-report",
                  "axe-json",
                  "manual-attestation"
                ]
              },
              "path": {
                "type": "string",
                "minLength": 1,
                "description": "Repo-relative or artifact-store path to the evidence file."
              },
              "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "created_at": { "type": "string", "format": "date-time" }
            }
          }
        },
        "waiver_ref": {
          "type": "string",
          "pattern": "^WVR-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]+$",
          "description": "Reference into the waiver register in TEST_GOVERNANCE.md (rule 3). Required when verdict=waived."
        },
        "attestation": { "$ref": "#/$defs/attestation" }
      },
      "allOf": [
        {
          "if": { "properties": { "verdict": { "const": "waived" } }, "required": ["verdict"] },
          "then": { "properties": { "waiver_ref": true }, "required": ["waiver_ref"] }
        },
        {
          "if": {
            "properties": {
              "evidence": {
                "type": "array",
                "contains": {
                  "type": "object",
                  "properties": { "type": { "const": "manual-attestation" } },
                  "required": ["type"]
                }
              }
            },
            "required": ["evidence"]
          },
          "then": { "properties": { "attestation": true }, "required": ["attestation"] }
        }
      ]
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attestor", "rubric_ref", "checklist_item_results", "date"],
      "properties": {
        "attestor": {
          "type": "string",
          "minLength": 1,
          "description": "Named human (or named reviewing agent distinct from the change author — TEST_GOVERNANCE.md rule 4)."
        },
        "rubric_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Pointer to the rubric applied, e.g. 'docs/qa-checklist.md#Layout' or the matrix entry's rubric field."
        },
        "checklist_item_results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["item", "result"],
            "properties": {
              "item": { "type": "string", "minLength": 1 },
              "result": { "enum": ["pass", "fail", "not-applicable"] },
              "note": { "type": "string" }
            }
          }
        },
        "date": { "type": "string", "format": "date" }
      }
    }
  }
}
